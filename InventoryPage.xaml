<UserControl
    x:Class="DiapStash_Plugin.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,15">
            <TextBlock Text="Current Catalog Inventory Statistics" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Refresh Catalog" Click="RefreshStock_Click" Margin="20,0,0,0"/>
            <Button Content="🔍 Inspect Raw JSON" Click="InspectRawStock_Click" Margin="10,0,0,0" Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="InventoryCardsGrid" Margin="0,5,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="400" ItemHeight="160" MaximumRowsOrColumns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,16,16" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="110" Height="120" Margin="0,0,16,0" VerticalAlignment="Center">
                                    <Border CornerRadius="8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" VerticalAlignment="Top" Spacing="8">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" MaxLines="2"/>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="8,3,8,3" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE916;" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                                    <TextBlock Text="Size" FontSize="11" FontWeight="Medium" Opacity="0.9" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text=":" FontSize="11" FontWeight="Medium" Opacity="0.9" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Size}" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="4" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding Left}" FontSize="24" FontWeight="Black" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Bottom" LineHeight="24"/>
                                        <TextBlock Text="left" FontSize="12" Opacity="0.5" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBox Grid.Row="2" x:Name="RawStockDiagnosticBox" Header="Raw Endpoint JSON Response" Margin="0,15,0,0" Height="150" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" FontSize="11" FontFamily="Cascadia Code, Consolas" Visibility="Collapsed"/>
    </Grid>
</UserControl>