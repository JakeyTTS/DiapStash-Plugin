<UserControl
    x:Class="DiapStash_Plugin.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,15">
            <TextBlock Text="Current Catalog Inventory Statistics" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold" VerticalAlignment="Center"/>

            <ToggleSwitch x:Name="StockFilterToggle" 
                          Header="Filter Instock Only" 
                          IsOn="True" 
                          Toggled="StockFilterToggle_Toggled" 
                          Margin="25,-5,0,0" 
                          VerticalAlignment="Center"
                          OnContent="Active Stock" 
                          OffContent="Show All Registry"/>

            <Button x:Name="RefreshBtn" Click="RefreshStock_Click" Margin="25,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="Refresh Catalog" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="InspectBtn" Click="InspectRawStock_Click" Margin="10,0,0,0" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE1A3;" FontSize="14" />
                    <TextBlock Text="Inspect Raw JSON" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1">
            <InfoBar x:Name="InventoryInfoBar" Severity="Informational" IsOpen="False" IsClosable="False" Margin="0,5,0,10" VerticalAlignment="Top"/>

            <GridView x:Name="InventoryCardsGrid" 
                      Margin="0,5,0,0" 
                      Padding="0,0,0,20"
                      SelectionMode="None"
                      IsItemClickEnabled="False">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="360" Height="150" Margin="0,0,12,12" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="100" Height="115" Margin="0,0,16,0" VerticalAlignment="Center">
                                    <Border CornerRadius="6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Grid>
                                            <Image Source="{Binding ImageUrl}" 
                                                   Stretch="UniformToFill" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" VerticalAlignment="Top" Spacing="6">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxLines="2"/>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="8,3,8,3" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE916;" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                                    <TextBlock Text="Size" FontSize="11" FontWeight="Medium" Opacity="0.9" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text=":" FontSize="11" FontWeight="Medium" Opacity="0.9" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Size}" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Spacing="4">
                                        <TextBlock Text="{Binding Left}" FontSize="24" FontWeight="Black" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Bottom" LineHeight="24"/>
                                        <TextBlock Text="left" FontSize="12" Opacity="0.5" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>

        <TextBox Grid.Row="2" x:Name="RawStockDiagnosticBox" Header="Raw Endpoint JSON Response" Margin="0,15,0,0" Height="140" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" FontSize="11" FontFamily="Cascadia Code, Consolas" Visibility="Collapsed"/>
    </Grid>
</UserControl>