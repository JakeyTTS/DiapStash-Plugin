<UserControl
    x:Class="DiapStash_Plugin.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left" Margin="4,4,4,40">
            
            <TextBlock x:Uid="SettingsTitle" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>

            <!-- Theme Settings -->
            <StackPanel Spacing="10">
                <TextBlock x:Uid="SettingsAppearanceSubtitle" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <ComboBox x:Name="ThemeComboBox" x:Uid="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" Width="200">
                    <ComboBoxItem x:Uid="ThemeItemDefault" Tag="Default"/>
                    <ComboBoxItem x:Uid="ThemeItemLight" Tag="Light"/>
                    <ComboBoxItem x:Uid="ThemeItemDark" Tag="Dark"/>
                </ComboBox>
            </StackPanel>

            <MenuFlyoutSeparator Margin="0,10"/>

            <!-- JakeyTTS Settings -->
            <StackPanel Spacing="10">
                <TextBlock x:Uid="SettingsJakeyTtsSubtitle" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <TextBox x:Name="TtsServerBox" x:Uid="TtsServerBox" Text="ws://localhost:8889/" Width="400" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                    <Button x:Name="ConnectTtsBtn" x:Uid="BtnStartLoop" Click="ConnectTts_Click" Style="{StaticResource AccentButtonStyle}" Width="180"/>
                    <Button x:Name="DisconnectTtsBtn" x:Uid="BtnStopSync" Click="DisconnectTts_Click" IsEnabled="False" Width="110"/>
                </StackPanel>
            </StackPanel>

            <MenuFlyoutSeparator Margin="0,10"/>

            <!-- DiapStash Settings -->
            <StackPanel Spacing="10">
                <TextBlock x:Uid="SettingsDiapStashSubtitle" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <TextBlock x:Uid="SettingsDiapStashDesc" FontSize="13" Opacity="0.6"/>

                <StackPanel Spacing="12" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,8">
                        <Button x:Name="AuthBtn" Content="Link DiapStash Account" Click="OpenPortal_Click" Style="{StaticResource AccentButtonStyle}" Width="210" Height="36"/>
                        <Button x:Name="ChangeAccountBtn" Content="Change Account" Click="ChangeAccount_Click" Width="150" Height="36" ToolTipService.ToolTip="Login with a different account using the same API credentials."/>
                    </StackPanel>

                    <TextBox x:Name="StashTokenBox" Header="Active Access Bearer Token (Auto-Generated Framework Context)" PlaceholderText="Awaiting secure OAuth2 local loopback workflow handshake tokens..." IsReadOnly="True" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
    
    </Grid>
</UserControl>
