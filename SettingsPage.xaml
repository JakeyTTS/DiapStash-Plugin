<UserControl
    x:Class="DiapStash_Plugin.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left" Margin="4,4,4,40">
            
            <TextBlock x:Uid="SettingsTitle" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>

            <!-- Theme Settings -->
            <StackPanel Spacing="10">
                <TextBlock x:Uid="SettingsAppearanceSubtitle" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <ComboBox x:Name="ThemeComboBox" x:Uid="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" Width="200">
                    <ComboBoxItem x:Uid="ThemeItemDefault" Tag="Default"/>
                    <ComboBoxItem x:Uid="ThemeItemLight" Tag="Light"/>
                    <ComboBoxItem x:Uid="ThemeItemDark" Tag="Dark"/>
                </ComboBox>
            </StackPanel>

            <MenuFlyoutSeparator Margin="0,10"/>

            <!-- JakeyTTS Settings -->
            <StackPanel Spacing="10">
                <TextBlock x:Uid="SettingsJakeyTtsSubtitle" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <TextBox x:Name="TtsServerBox" x:Uid="TtsServerBox" Text="ws://localhost:8889/" Width="400" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                    <Button x:Name="ConnectTtsBtn" x:Uid="BtnStartLoop" Click="ConnectTts_Click" Style="{StaticResource AccentButtonStyle}" Width="180"/>
                    <Button x:Name="DisconnectTtsBtn" x:Uid="BtnStopSync" Click="DisconnectTts_Click" IsEnabled="False" Width="110"/>
                </StackPanel>
            </StackPanel>

            <MenuFlyoutSeparator Margin="0,10"/>

            <!-- DiapStash Settings -->
            <StackPanel Spacing="10">
                <TextBlock x:Uid="SettingsDiapStashSubtitle" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <TextBlock x:Uid="SettingsDiapStashDesc" FontSize="13" Opacity="0.6"/>

                <StackPanel Spacing="12" Margin="0,10,0,0">
                    <TextBox x:Name="ClientIdBox" Header="OAuth2 Client ID Target" PlaceholderText="Paste generated DiapStash Client ID string parameter here..." HorizontalAlignment="Stretch"/>
                    <PasswordBox x:Name="ClientSecretBox" Header="OAuth2 Client Secret Key" PlaceholderText="Paste secure DiapStash Client Secret data payload here..." HorizontalAlignment="Stretch"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,8">
                        <Button x:Name="AuthBtn" Content="Link DiapStash Account" Click="OpenPortal_Click" Style="{StaticResource AccentButtonStyle}" Width="210" Height="36"/>
                        <Button x:Name="ChangeAccountBtn" Content="Change Account" Click="ChangeAccount_Click" Width="150" Height="36" ToolTipService.ToolTip="Login with a different account using the same API credentials."/>
                    </StackPanel>

                    <TextBox x:Name="StashTokenBox" Header="Active Access Bearer Token (Auto-Generated Framework Context)" PlaceholderText="Awaiting secure OAuth2 local loopback workflow handshake tokens..." IsReadOnly="True" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <Button x:Name="LaunchSetupWizardBtn" x:Uid="BtnLaunchSetupWizard" Click="LaunchSetupWizard_Click" Margin="0,15,0,0" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Padding="10"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
    
    <!-- Setup Wizard Dialog -->
    <ContentDialog x:Name="SetupWizardDialog" 
                   x:Uid="SetupWizardDialog"
                   PrimaryButtonText="Next" 
                   SecondaryButtonText="Back" 
                   CloseButtonText="Cancel"
                   PrimaryButtonClick="SetupWizardDialog_PrimaryButtonClick"
                   SecondaryButtonClick="SetupWizardDialog_SecondaryButtonClick">
        <Grid Width="500" MinHeight="300" Margin="0,10,0,0">
            <!-- Step 1 -->
            <StackPanel x:Name="WizardStep1" Spacing="16">
                <TextBlock Text="Welcome to the DiapStash automation bridge! This wizard will help you link your DiapStash cloud account." TextWrapping="Wrap"/>
                <TextBlock x:Uid="WizardStep1Title" FontWeight="SemiBold" FontSize="15"/>
                <HyperlinkButton Content="🔗 Click here to request API access links (account#api)" NavigateUri="https://account.diapstash.com/account#api" Padding="0"/>
                <TextBlock Text="Once the window loads, click on the purple 'Create API client' button target action panel." FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Step 2 -->
            <StackPanel x:Name="WizardStep2" Spacing="16" Visibility="Collapsed">
                <TextBlock x:Uid="WizardStep2Title" FontWeight="SemiBold" FontSize="15"/>
                <Grid RowSpacing="12" ColumnSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Client Name:" FontSize="13" Opacity="0.7" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="JakeyTTS Automation Bridge" IsReadOnly="True" FontSize="13" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Logo URL:" FontSize="13" Opacity="0.7" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="https://raw.githubusercontent.com/abdldavid/DiapStash-Plugin/master/Assets/LargeTile.scale-400.png" IsReadOnly="True" FontSize="11" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Application Type:" FontSize="13" Opacity="0.7" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="6,2,6,2">
                            <TextBlock Text="CRITICAL: API Server" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Redirect URLs:" FontSize="13" Opacity="0.7" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="http://localhost:8888/" IsReadOnly="True" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"/>
                </Grid>
            </StackPanel>

            <!-- Step 3 -->
            <StackPanel x:Name="WizardStep3" Spacing="16" Visibility="Collapsed">
                <TextBlock x:Uid="WizardStep3Title" FontWeight="SemiBold" FontSize="15"/>
                <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1" CornerRadius="4" Padding="15">
                    <TextBlock Text="⚠️ Check ALL available scope checkboxes boxes (History, Stock, Custom Types) to prevent runtime pipeline crashes." FontSize="14" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>
                <TextBlock Text="After selecting the scopes, click 'Save' to generate your API keys." TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Step 4 -->
            <StackPanel x:Name="WizardStep4" Spacing="16" Visibility="Collapsed">
                <TextBlock x:Uid="WizardStep4Title" FontWeight="SemiBold" FontSize="15"/>
                <TextBlock Text="Copy your newly generated Client ID and Client Secret strings and paste them below:" FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                
                <TextBox x:Name="WizardClientIdBox" Header="OAuth2 Client ID Target" PlaceholderText="Paste Client ID..." HorizontalAlignment="Stretch"/>
                <PasswordBox x:Name="WizardClientSecretBox" Header="OAuth2 Client Secret Key" PlaceholderText="Paste Client Secret..." HorizontalAlignment="Stretch"/>
                
                <TextBlock Text="Click 'Finish' to save and initialize the local loopback server to authorize the application." FontSize="12" FontStyle="Italic" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </ContentDialog>
    </Grid>
</UserControl>
