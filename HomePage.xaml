<UserControl
    x:Class="DiapStash_Plugin.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">

            <Image Source="ms-appx:///Assets/StoreLogo.png" Width="120" Height="120" Stretch="Uniform" HorizontalAlignment="Center"/>

            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="DiapStash Automation Hub" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusMessageLabel" Text="Validating API infrastructure context..." FontSize="13" Opacity="0.6" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                <ProgressRing x:Name="StatusLoadingRing" IsActive="True" Width="24" Height="24" VerticalAlignment="Center"/>
                <Button x:Name="ConfigureApiBtn" Content="⚙️ Configure Client ID" Click="ConfigureApi_Click" Visibility="Collapsed" Style="{StaticResource AccentButtonStyle}" Padding="24,8,24,8"/>
                <Button x:Name="LoginPortalBtn" Content="🔐 Execute Portal Login" Click="LoginPortal_Click" Visibility="Collapsed" Style="{StaticResource AccentButtonStyle}" Padding="24,8,24,8"/>

                <Button x:Name="ConnectTtsBtn" Content="🔌 Connect JakeyTTS" Click="ConnectTts_Click" Visibility="Collapsed" Style="{StaticResource DefaultButtonStyle}" Padding="24,8,24,8"/>
            </StackPanel>
        </StackPanel>

        <Button Content="📋 View Telemetry Logs" Click="OpenFloatingLog_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10" Style="{StaticResource DefaultButtonStyle}"/>
    </Grid>
</UserControl>