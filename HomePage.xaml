<UserControl
    x:Class="DiapStash_Plugin.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="12">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">

            <Image Source="ms-appx:///Assets/StoreLogo.scale-400.png" Width="120" Height="120" Stretch="Uniform" HorizontalAlignment="Center"/>

            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock x:Uid="HomeTitle" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Red" VerticalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock x:Name="StatusMessageLabel" Text="Validating API infrastructure context..." FontSize="13" Opacity="0.6" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                <ProgressRing x:Name="StatusLoadingRing" IsActive="True" Width="24" Height="24" VerticalAlignment="Center"/>
                <Button x:Name="ConfigureApiBtn" x:Uid="BtnOpenSettings" Click="ConfigureApi_Click" Visibility="Collapsed" Style="{StaticResource AccentButtonStyle}" Padding="24,8,24,8"/>
                <Button x:Name="LoginPortalBtn" x:Uid="BtnExecuteLogin" Click="LoginPortal_Click" Visibility="Collapsed" Style="{StaticResource AccentButtonStyle}" Padding="24,8,24,8"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="10">
            <Button x:Name="TopRightAccountBtn" x:Uid="BtnSwitchAccount" Click="LoginPortal_Click" Style="{StaticResource DefaultButtonStyle}"/>
        </StackPanel>

        <Button x:Uid="BtnViewLogs" Click="OpenFloatingLog_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource DefaultButtonStyle}"/>
    </Grid>
</UserControl>