<UserControl
    x:Class="DiapStash_Plugin.ChangeTrackerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiapStash_Plugin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:TargetVariableToVisibilityConverter x:Key="TargetVarToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
            <TextBlock Text="Active Operational Status Timeline" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Poll Current Status" Click="RefreshChange_Click" Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Padding="0,0,15,0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="25">

                    <Border x:Name="StatusCardFrame" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="25" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Width="140" Height="140" Margin="0,0,25,0" VerticalAlignment="Top">
                                <Border CornerRadius="8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Image x:Name="CardProductImage" Stretch="UniformToFill" Source="https://diapstash.com/diapstash/assets/icons/Diaper.svg" RenderTransformOrigin="0.5,0.5"/>
                                </Border>
                                <Border x:Name="CardStatusBadge" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="-5,-5,0,0" Padding="8,4,8,4" CornerRadius="4" Background="{ThemeResource SystemAccentColor}">
                                    <TextBlock x:Name="CardStatusBadgeText" Text="ACTIVE" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <Grid>
                                    <TextBlock x:Name="CardProductName" Text="Loading Product Identity..." Style="{StaticResource TitleTextBlockStyle}" FontSize="22" FontWeight="SemiBold"/>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="6,2,6,2">
                                        <TextBlock x:Name="CardProductSize" Text="Size: N/A" Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE916;" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}"/>
                                    <TextBlock x:Name="CardElapsedTimeDisplay" Text="Elapsed: 00h 00m" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}"/>
                                </StackPanel>

                                <MenuFlyoutSeparator Margin="0,5"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.6">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE121;" FontSize="12" />
                                            <TextBlock Text="Placement Target Start Time" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                        <TextBlock x:Name="CardStartTimeDisplay" Text="--/--/---- --:--" FontSize="13" FontWeight="Medium"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.6">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70F;" FontSize="12" />
                                            <TextBlock Text="Session Activity Note Context" Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                        <TextBlock x:Name="CardNotesDisplay" Text="No session context log entries attached." FontSize="13" FontStyle="Italic" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                    <Border x:Name="BadgeLeak" Visibility="Collapsed" Padding="8,4,8,4" Background="{ThemeResource SystemFillColorCriticalBrush}" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7BA;" FontSize="10" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            <TextBlock Text="LEAK DETECTED" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="BadgeWet" Visibility="Collapsed" Padding="8,4,8,4" Background="{ThemeResource SystemFillColorCautionBrush}" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE4C6;" FontSize="10" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            <TextBlock x:Name="BadgeWetText" Text="WET (0/5)" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="BadgeMessy" Visibility="Collapsed" Padding="8,4,8,4" Background="{ThemeResource SystemFillColorAttentionBrush}" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7BA;" FontSize="10" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            <TextBlock x:Name="BadgeMessyText" Text="MESSY (0/3)" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <InfoBar x:Name="NoActiveSessionInfoBar" Severity="Informational" Title="Timeline Idle" Message="Awaiting active sequence signals." IsOpen="True" IsClosable="False"/>

                    <StackPanel Spacing="10" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Default DiapStash Response Blueprint" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="15"/>
                            <TextBlock Text=" {diapstash_change}" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="15" Foreground="MediumOrchid" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="Design the primary core message framework read out loud by JakeyTTS. To include your conditional rules configured down below, remember to drop their exact dynamic token handle tag (e.g. {diapstash_rule_myruleblockname}) into this framework container." FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                        <TextBox x:Name="CustomTtsTemplateBox" Header="Core DiapStash Notification Template" Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
                        <Button x:Name="SaveTemplateBtn" Content="Save Core Response Framework" Click="SaveTtsTemplate_Click" Style="{StaticResource AccentButtonStyle}" Width="240"/>
                    </StackPanel>

                    <MenuFlyoutSeparator Margin="0,10"/>

                    <StackPanel Spacing="15">
                        <Grid>
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE71C;" FontSize="15" />
                                    <TextBlock Text="Conditional Rule Injector Matrix" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="15"/>
                                </StackPanel>
                                <TextBlock Text="Create complex conditional trees (IF / AND / ELSE IF) inside isolated card blocks. Click on the block headers to edit their identifier tag string." FontSize="12" Opacity="0.6"/>
                            </StackPanel>
                            <Button Click="AddRule_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" FontSize="12" />
                                    <TextBlock Text="Add New Rule Block Card" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ItemsControl x:Name="RulesListView">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,16" Background="{ThemeResource LayerFillColorAltBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                        <StackPanel Spacing="12">

                                            <Grid>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9E9;" FontSize="14" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,2,0"/>
                                                    <TextBox Text="{Binding CardName, Mode=TwoWay}" PlaceholderText="rule_name" FontWeight="Black" Foreground="{ThemeResource SystemAccentColor}" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="6,2,6,2" VerticalAlignment="Center" FontSize="14" Width="140"/>

                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Opacity="0.6">
                                                        <TextBlock Text="➔ Token representation: " FontSize="13" FontStyle="Italic"/>
                                                        <TextBlock Text="{}{diapstash_rule_" FontSize="13" FontWeight="Bold" Foreground="MediumOrchid"/>
                                                        <TextBlock Text="{Binding CardName}" FontSize="13" FontWeight="Bold" Foreground="MediumOrchid"/>
                                                        <TextBlock Text="}" FontSize="13" FontWeight="Bold" Foreground="MediumOrchid"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                                    <Button Click="AddClause_Click" Style="{StaticResource DefaultButtonStyle}" FontSize="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE710;" FontSize="10" />
                                                            <TextBlock Text="Add Line Clause" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Click="DeleteCard_Click" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Background="Transparent" BorderThickness="0" FontSize="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" FontSize="10" />
                                                            <TextBlock Text="Delete Block" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <MenuFlyoutSeparator/>

                                            <ItemsControl ItemsSource="{Binding Clauses}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,8" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="105"/>
                                                                <ColumnDefinition Width="135"/>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0" SelectedValue="{Binding LogicalOperator, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,0,6,0">
                                                                <ComboBoxItem Content="IF"/>
                                                                <ComboBoxItem Content="AND"/>
                                                                <ComboBoxItem Content="ELSE IF"/>
                                                                <ComboBoxItem Content="ELSE"/>
                                                            </ComboBox>

                                                            <ComboBox Grid.Column="1" SelectedValue="{Binding TargetVariable, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                                                      Visibility="{Binding IsConditionalClause, Converter={StaticResource BoolToVis}}">
                                                                <ComboBoxItem Content="Leak"/>
                                                                <ComboBoxItem Content="Blowout"/>
                                                                <ComboBoxItem Content="Status"/>
                                                                <ComboBoxItem Content="Wetness"/>
                                                                <ComboBoxItem Content="Messy"/>
                                                            </ComboBox>

                                                            <ComboBox Grid.Column="2" SelectedValue="{Binding ConditionType, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Margin="0,0,6,0" IsEnabled="{Binding IsNumericControl}"
                                                                      Visibility="{Binding IsConditionalClause, Converter={StaticResource BoolToVis}}">
                                                                <ComboBoxItem Content="Equals"/>
                                                                <ComboBoxItem Content="GreaterThan" Visibility="{Binding IsNumericControl, Converter={StaticResource BoolToVis}}"/>
                                                                <ComboBoxItem Content="LessThan" Visibility="{Binding IsNumericControl, Converter={StaticResource BoolToVis}}"/>
                                                            </ComboBox>

                                                            <Grid Grid.Column="3" Margin="0,0,6,0" Visibility="{Binding IsConditionalClause, Converter={StaticResource BoolToVis}}">
                                                                <ComboBox SelectedValue="{Binding TargetValue, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Visibility="{Binding IsTextControl, Converter={StaticResource BoolToVis}}">
                                                                    <ComboBoxItem Content="YES"/>
                                                                    <ComboBoxItem Content="NO"/>
                                                                </ComboBox>
                                                                <ComboBox SelectedValue="{Binding TargetValue, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Visibility="{Binding IsStatusControl, Converter={StaticResource BoolToVis}}">
                                                                    <ComboBoxItem Content="Active"/>
                                                                    <ComboBoxItem Content="Completed"/>
                                                                </ComboBox>
                                                                <ComboBox SelectedValue="{Binding TargetValue, Mode=TwoWay}" SelectedValuePath="Content" HorizontalAlignment="Stretch" Visibility="{Binding IsNumericControl, Converter={StaticResource BoolToVis}}">
                                                                    <ComboBoxItem Content="0"/>
                                                                    <ComboBoxItem Content="1"/>
                                                                    <ComboBoxItem Content="2"/>
                                                                    <ComboBoxItem Content="3"/>
                                                                    <ComboBoxItem Content="4" Visibility="{Binding TargetVariable, Converter={StaticResource TargetVarToVis}, ConverterParameter=Wetness}"/>
                                                                    <ComboBoxItem Content="5" Visibility="{Binding TargetVariable, Converter={StaticResource TargetVarToVis}, ConverterParameter=Wetness}"/>
                                                                </ComboBox>
                                                            </Grid>

                                                            <TextBox Grid.Column="4" Text="{Binding OutputMessage, Mode=TwoWay}" PlaceholderText="Phrase to output if this combined block condition matches..." Margin="0,0,6,0"
                                                                     Visibility="{Binding IsLastInLogicalBlock, Converter={StaticResource BoolToVis}}"/>

                                                            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="2">
                                                                <Button Click="MoveClauseUp_Click" Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Move Clause Up">
                                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70E;" FontSize="10"/>
                                                                </Button>
                                                                <Button Click="MoveClauseDown_Click" Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Move Clause Down">
                                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE70D;" FontSize="10"/>
                                                                </Button>
                                                                <Button Click="DeleteClause_Click" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Background="Transparent" BorderThickness="0" Padding="6,4,6,4">
                                                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="10"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Click="SaveRules_Click" Style="{StaticResource AccentButtonStyle}" Width="240">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74E;" FontSize="14" />
                                                            <TextBlock Text="Save Rules Matrix Hierarchy" VerticalAlignment="Center" />
                                                        </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Click="InspectRawChange_Click" Style="{StaticResource DefaultButtonStyle}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE1A3;" FontSize="14" />
                                                            <TextBlock Text="Inspect Raw JSON" VerticalAlignment="Center" />
                                                        </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <TextBox x:Name="RawChangeDiagnosticBox" Header="Raw Endpoint JSON Response" Height="150" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" FontSize="11" FontFamily="Cascadia Code, Consolas" Visibility="Collapsed" Margin="0,10,0,0"/>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorAltBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="15" VerticalAlignment="Top">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,5">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE946;" FontSize="16" Foreground="MediumOrchid"/>
                        <TextBlock Text="Variable Guide Reference" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <TextBlock Text="Drop these tokens inside your blueprint string container on the left." FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                    <MenuFlyoutSeparator/>
                    <StackPanel Spacing="10">
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_change}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Unified variable containing your entire customized blueprint framework string text output." FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_rule_[block_name]}" FontWeight="SemiBold" FontSize="12" Foreground="DodgerBlue"/>
                            <TextBlock Text="Dynamic token generated automatically from your custom cards below (e.g. {diapstash_rule_alertafuga})." FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_product}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Brand &amp; diaper item model name." FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_size}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Active diaper size (e.g. L/XL)." FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_wetness}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Current wetness scale (e.g. 2/5 - 40%)." FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_messy}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Current mess scale (e.g. 1/3 - 33%)." FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_elapsed}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Hours and minutes running duration." FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_leak}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Returns YES or NO status alerts." FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{}{diapstash_status}" FontWeight="SemiBold" FontSize="12" Foreground="MediumOrchid"/>
                            <TextBlock Text="Outputs Active or Completed." FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>