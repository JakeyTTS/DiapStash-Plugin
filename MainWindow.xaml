<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DiapStash_Plugin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiapStash_Plugin"
    Title="DiapStash - Stream Automation Hub">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed" Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="NavHome" Tag="Home" Icon="Home"/>
                <NavigationViewItem x:Uid="NavInventory" Tag="Inventory">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B8;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="NavChangeLog" Tag="ChangeTracker">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Uid="NavStreaming" Icon="Video" Tag="Streaming" />
            </NavigationView.MenuItems>

            <ContentPresenter x:Name="MainContentFrame" Padding="25"/>
        </NavigationView>
    </Grid>
</Window>