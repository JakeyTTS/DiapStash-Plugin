<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DiapStash_Plugin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiapStash_Plugin"
    Title="DiapStash - Stream Automation Hub">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed" Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="Home" Icon="Home"/>
                <NavigationViewItem Content="Inventory" Tag="Inventory" Icon="AllApps"/>
                <NavigationViewItem Content="Change Log Stream" Tag="ChangeTracker" Icon="PostUpdate"/>
                <NavigationViewItem Content="DiapStash Portal" Tag="StashAuth" Icon="Contact"/>
                <NavigationViewItem Content="JakeyTTS Injections" Tag="Injections" Icon="Share"/>
            </NavigationView.MenuItems>

            <ContentPresenter x:Name="MainContentFrame" Padding="25"/>
        </NavigationView>
    </Grid>
</Window>