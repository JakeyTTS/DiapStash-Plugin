<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DiapStash_Plugin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiapStash_Plugin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DiapStash - Stream Automation Hub">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Height="40" Background="Transparent" VerticalAlignment="Top" Padding="15,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE929;" FontSize="16" Foreground="MediumOrchid"/>
                <TextBlock Text="DiapStash Stream Automation Platform" FontSize="12" FontWeight="SemiBold" Opacity="0.8"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView" Grid.Row="1" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed" ItemInvoked="NavView_ItemInvoked" Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard Core" Tag="Home" Icon="Home"/>
                <NavigationViewItem Content="DiapStash Portal" Tag="StashAuth" Icon="Contact"/>
                <NavigationViewItem Content="Stash Inventory" Tag="Inventory" Icon="AllApps"/>
                <NavigationViewItem Content="Change Log Stream" Tag="ChangeTracker" Icon="PostUpdate"/>
                <NavigationViewItem Content="JakeyTTS Injections" Tag="Injections" Icon="Share"/>
            </NavigationView.MenuItems>

            <Grid Padding="25">

                <Grid x:Name="PageHome" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="System Console Logging Telemetry" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,15"/>
                    <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <ScrollViewer x:Name="LogScroll" Padding="15" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogBlock" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" PlaceholderText="Awaiting thread execution logs..." BorderThickness="0" Background="Transparent" FontSize="12" FontFamily="Cascadia Code, Consolas"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid x:Name="PageStashAuth" Visibility="Collapsed">
                    <StackPanel Spacing="15" MaxWidth="700" HorizontalAlignment="Left">
                        <TextBlock Text="DiapStash Account Authentication Portal" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        <TextBlock Text="1. Click the authorization helper button down below to visit the web developer interface registry portal." TextWrapping="Wrap" Opacity="0.8"/>
                        <TextBlock Text="2. Generate your secure OAuth2 Application Client token string." TextWrapping="Wrap" Opacity="0.8"/>
                        <TextBlock Text="3. Paste the provided Bearer Secret into the token field to establish authorization data paths." TextWrapping="Wrap" Opacity="0.8"/>

                        <Button Content="Open DiapStash Developer Portal" Click="OpenPortal_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,10,0,10"/>
                        <PasswordBox x:Name="StashTokenBox" Header="DiapStash Bearer Security Key" PlaceholderText="Paste token string here..." PasswordChanged="StashTokenBox_PasswordChanged"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="PageInventory" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,15">
                        <TextBlock Text="Current Catalog Inventory Statistics" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Refresh Catalog" Click="RefreshStock_Click" Margin="20,0,0,0" HorizontalAlignment="Right"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="ProductPreviewImage" Source="ms-appx:///Assets/StoreLogo.png" Width="140" Height="140" Margin="0,0,20,0" VerticalAlignment="Top" Stretch="UniformToFill" AutomationProperties.Name="Inventory Graphic Display representation asset"/>
                            <TextBlock Grid.Column="1" x:Name="InventoryDumpBlock" Text="No cached stock entries present. Connect framework and hit refresh." TextWrapping="Wrap" FontSize="14" Opacity="0.8"/>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="PageChangeTracker" Visibility="Collapsed">
                    <StackPanel Spacing="15" MaxWidth="700" HorizontalAlignment="Left">
                        <TextBlock Text="Active Operational Logs Tracker" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        <Button Content="Poll Current Change Status" Click="RefreshChange_Click" Margin="0,0,0,10"/>
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <TextBlock x:Name="ChangeTrackerOutputBlock" Text="Awaiting runtime evaluation sequence signal requests." TextWrapping="Wrap" FontSize="14" Opacity="0.8"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="PageInjections" Visibility="Collapsed">
                    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Left">
                        <TextBlock Text="JakeyTTS Main Bridge Core Sync" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        <TextBox x:Name="TtsServerBox" Header="Core WebSocket Server Endpoint Address" Text="ws://localhost:8889/"/>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Button x:Name="ConnectBtn" Content="Start Loop Automation" Click="Connect_Click" Style="{StaticResource AccentButtonStyle}" Width="180"/>
                            <Button x:Name="DisconnectBtn" Content="Stop Sync" Click="Disconnect_Click" IsEnabled="False" Width="110"/>
                        </StackPanel>

                        <MenuFlyoutSeparator Margin="0,10"/>

                        <TextBlock Text="Natively Embed Panel into JakeyTTS Window Workspace" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Pushes this operational panel configuration directly into the running instance workspace window layout of JakeyTTS using WebView2 structures remotely over the connected websocket channel stack handle." TextWrapping="Wrap" Opacity="0.7" FontSize="13"/>
                        <Button x:Name="InjectUiBtn" Content="Inject Panel Frame UI" Click="InjectUi_Click" IsEnabled="False" Width="180"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </NavigationView>
    </Grid>
</Window>