<UserControl
    x:Class="DiapStash_Plugin.InjectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Left">
        <TextBlock Text="JakeyTTS Main Bridge Core Sync" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
        <TextBox x:Name="TtsServerBox" Header="Core WebSocket Server Endpoint Address" Text="ws://localhost:8889/"/>
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <Button x:Name="ConnectBtn" Content="Start Loop Automation" Click="Connect_Click" Style="{StaticResource AccentButtonStyle}" Width="180"/>
            <Button x:Name="DisconnectBtn" Content="Stop Sync" Click="Disconnect_Click" IsEnabled="False" Width="110"/>
        </StackPanel>
    </StackPanel>
</UserControl>