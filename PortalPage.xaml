<UserControl
    x:Class="DiapStash_Plugin.PortalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="750" HorizontalAlignment="Left" Margin="4">

            <StackPanel Spacing="4">
                <TextBlock Text="DiapStash OAuth2 Secure Authentication" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <TextBlock Text="Authorize this application plugin to communicate with your secure cloud profile datasets safely." FontSize="13" Opacity="0.6"/>
            </StackPanel>

            <Border Background="{ThemeResource LayerFillColorAltBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE946;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                        <TextBlock Text="Step-by-Step API Registration Guide" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <MenuFlyoutSeparator/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Step 1: Open Developer Panel Portal" FontWeight="SemiBold" FontSize="13"/>
                        <HyperlinkButton Content="🔗 Click here to request API access links (account#api)" NavigateUri="https://account.diapstash.com/account#api" Padding="0" Margin="0,-2,0,0"/>
                        <TextBlock Text="Once the window loads, click on the purple 'Create API client' button target action panel." FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Step 2: Complete the Creation Form Parameters" FontWeight="SemiBold" FontSize="13"/>
                        <Grid RowSpacing="8" ColumnSpacing="12" Margin="4,2,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Client Name:" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="JakeyTTS Automation Bridge" IsReadOnly="True" FontSize="12" Height="28" Padding="6,3,6,3" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Logo URL:" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="https://raw.githubusercontent.com/abdldavid/DiapStash-Plugin/master/Assets/LargeTile.scale-400.png" IsReadOnly="True" FontSize="11" Height="28" Padding="6,3,6,3" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Application Type:" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Border Background="MediumOrchid" CornerRadius="4" Padding="6,2,6,2">
                                    <TextBlock Text="CRITICAL: API Server" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Do NOT select JavaScript Web App!" FontSize="11" FontStyle="Italic" Opacity="0.6" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Redirect URLs:" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="http://localhost:8888/" IsReadOnly="True" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Height="28" Padding="6,3,6,3" Background="{ThemeResource ControlOnImageFillColorDefaultBrush}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Step 3: Select Scope Clearances Permissions" FontWeight="SemiBold" FontSize="13"/>
                        <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1" CornerRadius="4" Padding="10,6,10,6">
                            <TextBlock Text="⚠️ Check ALL available scope checkboxes boxes (History, Stock, Custom Types) to prevent runtime pipeline crashes." FontSize="12" FontWeight="Medium" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Step 4: Execute Application Link Authorization" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="Copy your newly generated Client ID and Client Secret strings, drop them into the input textboxes below, and click 'Link Account'." FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Spacing="12">
                <TextBox x:Name="ClientIdBox" Header="OAuth2 Client ID Target" PlaceholderText="Paste generated DiapStash Client ID string parameter here..." HorizontalAlignment="Stretch"/>
                <PasswordBox x:Name="ClientSecretBox" Header="OAuth2 Client Secret Key" PlaceholderText="Paste secure DiapStash Client Secret data payload here..." HorizontalAlignment="Stretch"/>

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,8">
                    <Button x:Name="AuthBtn" Content="Link DiapStash Account" Click="OpenPortal_Click" Style="{StaticResource AccentButtonStyle}" Width="210" Height="36"/>
                </StackPanel>

                <TextBox x:Name="StashTokenBox" Header="Active Access Bearer Token (Auto-Generated Framework Context)" PlaceholderText="Awaiting secure OAuth2 local loopback workflow handshake tokens..." IsReadOnly="True" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>