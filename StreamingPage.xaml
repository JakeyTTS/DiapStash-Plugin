<UserControl x:Class="DiapStash_Plugin.StreamingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1200">

    <Grid x:Name="MainRoot" Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="30,15" Background="Transparent">
            <Grid>
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Live Telemetry Studio" FontSize="26" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="ℹ️ OBS Help" Click="ObsHelpBtn_Click" Padding="15,8"/>
                    <Button Content="ℹ️ JakeyTTS Setup" Click="TtsHelpBtn_Click" Padding="15,8"/>
                    <Button Content="💾 Save Preset" Click="SaveBtn_Click" Padding="15,8"/>
                    <Button Content="🎬 Canvas Preview" Click="PreviewCanvasBtn_Click" Padding="15,8"/>
                    <Button Content="🚀 Send to OBS (Real Data)" Click="LaunchObsBtn_Click" Style="{StaticResource AccentButtonStyle}" Padding="15,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border x:Name="ObsSceneCanvas" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Margin="10">
                <Grid>
                    <Canvas x:Name="BackgroundGridCanvas" SizeChanged="BackgroundGridCanvas_SizeChanged" Opacity="0.6"/>

                    <TextBlock Text="WORKSPACE" Margin="0,20,0,0" Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24" FontWeight="Bold" CharacterSpacing="200"/>

                    <Border x:Name="WidgetArtboard" Width="800" Height="450" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Translation="0,0,32" RenderTransformOrigin="0.5,0.5">

                        <Border.RenderTransform>
                            <CompositeTransform x:Name="ArtboardTransform"/>
                        </Border.RenderTransform>

                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>

                        <Canvas x:Name="EditorCanvas" PointerPressed="EditorCanvas_PointerPressed">
                            <Border x:Name="PreviewImage" Width="80" Height="80" Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="8"
                                    Canvas.Left="50" Canvas.Top="50" ManipulationMode="TranslateX, TranslateY" ManipulationDelta="Element_ManipulationDelta" PointerPressed="Element_PointerPressed">
                                <FontIcon Glyph="&#xEB9F;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="24"/>
                            </Border>

                            <StackPanel x:Name="PreviewTextGroup" Canvas.Left="150" Canvas.Top="50" ManipulationMode="TranslateX, TranslateY" ManipulationDelta="Element_ManipulationDelta" PointerPressed="Element_PointerPressed">
                                <TextBlock x:Name="PreviewTitle" Text="TELEMETRY" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel x:Name="PreviewProductGroup" Canvas.Left="150" Canvas.Top="80" ManipulationMode="TranslateX, TranslateY" ManipulationDelta="Element_ManipulationDelta" PointerPressed="Element_PointerPressed">
                                <TextBlock x:Name="PreviewProduct" Text="Product Name (Size M)" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel x:Name="PreviewBars" Spacing="8" Canvas.Left="150" Canvas.Top="110" ManipulationMode="TranslateX, TranslateY" ManipulationDelta="Element_ManipulationDelta" PointerPressed="Element_PointerPressed">
                                <Border x:Name="PreviewWetBar" Height="10" Width="200" Background="#00BFFF" CornerRadius="5"/>
                                <Border x:Name="PreviewMessBar" Height="10" Width="200" Background="#CD853F" CornerRadius="5"/>
                            </StackPanel>

                            <Border x:Name="SelectionBox" BorderBrush="#00BFFF" BorderThickness="2" Visibility="Collapsed" IsHitTestVisible="False"/>
                            <Thumb x:Name="ResizeHandle" Width="14" Height="14" Background="#00BFFF" Visibility="Collapsed" DragDelta="ResizeHandle_DragDelta">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="7" BorderBrush="White" BorderThickness="2"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Canvas>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="FloatingInspector" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Width="340" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="30">
                <Grid Padding="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Properties" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="15">
                            <StackPanel x:Name="Properties_Global" Spacing="15">
                                <ToggleSwitch x:Name="UseRealDataToggle" Header="Use Real DiapStash Data" IsOn="True" Toggled="Control_Changed"/>
                                <TextBlock Text="Card Dimensions" FontWeight="SemiBold"/>
                                <Slider x:Name="CardWidthSlider" Header="Width (px)" Minimum="400" Maximum="1200" Value="800" ValueChanged="Control_Changed"/>
                                <Slider x:Name="CardHeightSlider" Header="Height (px)" Minimum="200" Maximum="800" Value="450" ValueChanged="Control_Changed"/>

                                <TextBlock Text="OBS Animation" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                <ComboBox x:Name="TransitionTypeCombo" Header="Entry FX" SelectionChanged="Control_Changed" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Fade In" IsSelected="True"/>
                                    <ComboBoxItem Content="Zoom In"/>
                                    <ComboBoxItem Content="Slide Left"/>
                                    <ComboBoxItem Content="Slide Right"/>
                                    <ComboBoxItem Content="Slide Top"/>
                                    <ComboBoxItem Content="Slide Bottom"/>
                                    <ComboBoxItem Content="Bounce Pop"/>
                                </ComboBox>
                                <Slider x:Name="TransitionSpeedSlider" Header="Speed (ms)" Minimum="100" Maximum="1500" Value="400" ValueChanged="Control_Changed"/>
                            </StackPanel>

                            <StackPanel x:Name="Properties_Title" Spacing="15" Visibility="Collapsed">
                                <TextBox x:Name="CustomTitleBox" Header="Fallback Title" Text="TELEMETRY" TextChanged="Control_Changed"/>
                                <Slider x:Name="TitleSizeSlider" Header="Font Size" Minimum="12" Maximum="60" Value="20" ValueChanged="Control_Changed"/>
                            </StackPanel>

                            <StackPanel x:Name="Properties_Product" Spacing="15" Visibility="Collapsed">
                                <TextBox x:Name="ProductBox" Header="Fallback Product Name" Text="Product Name (Size M)" TextChanged="Control_Changed"/>
                            </StackPanel>

                            <StackPanel x:Name="Properties_Image" Spacing="15" Visibility="Collapsed">
                                <ToggleSwitch x:Name="ShowImageToggle" Header="Visibility" IsOn="True" Toggled="Control_Changed"/>
                            </StackPanel>

                            <StackPanel x:Name="Properties_Meters" Spacing="15" Visibility="Collapsed">
                                <ToggleSwitch x:Name="ShowWetToggle" Header="Wet Bar" IsOn="True" Toggled="Control_Changed"/>
                                <TextBlock Text="Wet Bar Color"/>
                                <ColorPicker x:Name="WetColorPicker" ColorChanged="Color_Changed"/>
                                <ToggleSwitch x:Name="ShowMessToggle" Header="Mess Bar" IsOn="True" Toggled="Control_Changed"/>
                                <TextBlock Text="Mess Bar Color"/>
                                <ColorPicker x:Name="MessColorPicker" ColorChanged="Color_Changed"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border x:Name="FloatingLayers" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Width="260" HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="30">
                <Grid Padding="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Widget Layers" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    <ListView x:Name="WidgetLayersList" Grid.Row="1" SelectionChanged="WidgetLayersList_SelectionChanged" SelectedIndex="0" Background="Transparent">
                        <ListViewItem Content="⚙️ Card &amp; FX"/>
                        <ListViewItem Content="📝 Stream Title"/>
                        <ListViewItem Content="🏷️ Product Details"/>
                        <ListViewItem Content="🖼️ Product Image"/>
                        <ListViewItem Content="📊 Progress Indicators"/>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>